# Intelligence Stack — Environment Variables
# Copy this file to `.env` and fill in your values.
# NEVER commit your real `.env` file.

# ── AgentMail (sender account) ────────────────────────────────────
# Get from https://agentmail.to dashboard after creating an account.
# Format: am_us_<32 hex chars>
AGENTMAIL_API_KEY=am_us_REPLACE_ME

# ONE inbox per AgentMail account — your canonical address.
# Example: weatherbot@agentmail.to
AGENTMAIL_INBOX=YOUR_USERNAME@agentmail.to

# ── Home Location (geographic scope anchor) ───────────────────────
# The single home location the stack targets for alerts.
HOME_LAT=39.8645108
HOME_LON=-84.1321902
HOME_ZIP=00000
HOME_COUNTY="Your County, ST"
HOME_WFO=XXX                              # 3-letter NWS forecast office code (e.g. ILN)

# ── Alert Fan-Out ─────────────────────────────────────────────────
# Comma-separated list of email recipients for severe-weather alerts.
ALERT_RECIPIENTS=recipient1@example.com,recipient2@example.com,recipient3@example.com

# ── Telegram (operator heads-up for level 3+ alerts) ──────────────
TELEGRAM_HOME_CHAT_ID=

# ── Cadence (minutes between cron ticks) ──────────────────────────
WEATHER_POLL_INTERVAL_ACTIVE=15           # during SPC ENH+ or active warning
WEATHER_POLL_INTERVAL_QUIET=60            # otherwise

# ── Anti-spam cooldowns (minutes) ─────────────────────────────────
COOLDOWN_SAME_LEVEL=30
COOLDOWN_ESCALATION=5